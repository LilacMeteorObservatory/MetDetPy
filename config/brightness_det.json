{
    "description": {
        "preset_name_cn": "亮度突变检测器",
        "preset_name_en": "BrightnessDet",
        "intro_cn": "基于分区亮度跟踪的突变事件检测器，可检出闪电、火流星等大面积亮度突变事件。",
        "intro_en": "Partition-based brightness tracking detector for large-area brightness surge events like lightning, fireballs, etc."
    },
    "loader": {
        "name": "ThreadVideoLoader",
        "wrapper": "PyAVVideoWrapper",
        "hwaccel": null,
        "resize": 960,
        "exp_time": "auto",
        "merge_func": "max",
        "grayscale": true,
        "upper_bound": 0.34,
        "continue_on_err": false
    },
    "detector": {
        "name": "BrightnessDetector",
        "window_sec": 1,
        "cfg": {
            "brightness": {
                "grid_rows": 4,
                "grid_cols": 4,
                "ema_momentum": 0.95,
                "z_threshold": 3.0,
                "abs_threshold": 15.0,
                "global_ratio": 0.6,
                "min_cell_valid": 0.5
            }
        }
    },
    "collector": {
        "meteor_cfg": {
            "min_len": 15,
            "max_interval": 4,
            "time_range": [
                0,
                8
            ],
            "speed_range": [
                2,
                21
            ],
            "drct_range": [
                0,
                0.6
            ],
            "det_thre": 0.5,
            "thre2": 2048
        },
        "recheck_cfg": {
            "switch": false,
            "model": {
                "name": "YOLOModel",
                "weight_path": "./weights/yolov5s_v2.onnx",
                "dtype": "float32",
                "nms": true,
                "warmup": true,
                "pos_thre": 0.25,
                "nms_thre": 0.45,
                "multiscale_pred": 2,
                "multiscale_partition": 2
            }
        },
        "positive_cfg": {
            "positive_cates": [
                "METEOR",
                "RED_SPRITE",
                "BRIGHTNESS_EVENT"
            ]
        }
    }
}
